{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.ts" },
    { "source": "/print/(.*)", "destination": "/api/server.ts" },
    { "source": "/uploads/(.*)", "destination": "/dist/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}